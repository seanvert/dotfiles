configuration {
    modi: "combi";
    combi-modi: "window,drun";
    display-combi: "Procurar";
    
    /* As três linhas abaixo são as que garantem a ordem que você viu no terminal */
    sort: false;
    disable-history: true;
    combi-hide-mode-prefix: true;

    /* Outras opções que você já tinha e são boas */
    show-icons: true;
    terminal: "xfce4-terminal"; /* Ou o seu terminal de preferência */
}

/* Garanta que não haja nenhum @theme após as chaves que sobrescreva o sort */
